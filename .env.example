# OPTIONAL — seret.co.il already provides IMDB scores directly.
# Only set this if you want a fallback for movies where seret has no IMDB score.
# Free key at https://www.omdbapi.com/apikey.aspx (1,000 requests/day free)
OMDB_API_KEY=

# Port the web server listens on inside the container (default 5000)
PORT=5000
